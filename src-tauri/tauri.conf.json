{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fikstur-teklif-asistani",
  "version": "0.1.0",
  "identifier": "com.fikstur.teklif",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fikstur Teklif Asistanı",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tahatolga/teklif_asistani/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZERUNCRDcxMzgyM0VGQ0YKUldUUDd5TTRjYjNzYmJzT29DblV2OGlicTRTZHhqa3d3NmZWaUMrQWNadkc5dEwzTjdndzMwWmEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Turkish", "English"]
      }
    }
  }
}
